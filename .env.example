# Fill ONLY the keys for providers you plan to use.
# The app works with any non-empty subset.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Ollama needs no API key; override only if it runs on a different host/port.
OLLAMA_BASE_URL=http://localhost:11434

# Optional: proxy for youtube-transcript-api when your IP is blocked by YouTube.
# Leave empty unless you need it.
YT_PROXY_HTTP=
YT_PROXY_HTTPS=
