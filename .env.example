# ============================================================
# PolyChat — environment configuration
# Fill ONLY the keys for the providers you plan to use.
# ============================================================


# ------------------------------------------------------------
# LLM providers (fill at least one)
# ------------------------------------------------------------

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=


# ------------------------------------------------------------
# Ollama (no API key needed — fully offline)
# Override only if Ollama runs on a different host/port.
# ------------------------------------------------------------

OLLAMA_BASE_URL=http://localhost:11434


# ------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------

# HuggingFace token (Read permission) — removes the unauthenticated-request warning
# and raises rate limits when downloading models.
# Create a Read token at https://huggingface.co/settings/tokens
HF_TOKEN=


# ------------------------------------------------------------
# Optional — YouTube proxy
# Set only if your IP is blocked by YouTube (common on cloud VMs).
# ------------------------------------------------------------

YT_PROXY_HTTP=
YT_PROXY_HTTPS=
